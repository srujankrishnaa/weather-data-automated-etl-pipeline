  (
    -- Staging model for raw weather data
-- Reads from dev.raw_weather_data inserted by the Airflow pipeline




with source as (

SELECT * 
FROM "db"."dev"."raw_weather_data"

),

de_dup as (
    select 
    *,
    row_number() over (partition by time order by inserted_at desc) as rn
    from source
)

select 
