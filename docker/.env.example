# docker/.env.example
# Copy this to docker/.env and fill in your values

# ─── Superset Postgres connection ──────────────────────────────────────────────
DATABASE_DIALECT=postgresql+psycopg2
DATABASE_USER=superset
DATABASE_PASSWORD=superset
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_DB=superset_db

POSTGRES_DB=superset_db
POSTGRES_USER=superset
POSTGRES_PASSWORD=superset

# ─── Superset secret key (change this in production!) ─────────────────────────
SUPERSET_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_STRING

# ─── Superset behaviour ────────────────────────────────────────────────────────
SUPERSET_ENV=development
SUPERSET_LOAD_EXAMPLES=no
SUPERSET_PORT=8088
SUPERSET_LOG_LEVEL=info
SUPERSET_APP_ROOT=/
CYPRESS_CONFIG=false
MAPBOX_API_KEY=''

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CELERY_DB=0
REDIS_RESULTS_DB=1

# ─── Examples DB (leave as-is) ────────────────────────────────────────────────
EXAMPLES_DB=examples_db
EXAMPLES_HOST=db
EXAMPLES_PORT=5432
EXAMPLES_USER=examples
EXAMPLES_PASSWORD=examples
